# MongoDB Configuration
# Project: Node App High-Availability (Incresol Software Services)
# Configured for Replica Set: {{ replica_set_name }}

storage:
  dbPath: {{ mongodb_data_dir }}
  journal:
    enabled: true

systemLog:
  destination: file
  logAppend: true
  path: {{ mongodb_log_dir }}/mongod.log

net:
  port: {{ mongodb_port }}
  bindIp: 0.0.0.0

replication:
  replSetName: "{{ replica_set_name }}"

processManagement:
  timeZoneInfo: /usr/share/zoneinfo
